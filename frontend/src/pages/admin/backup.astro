---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="FilaMan - Database Backup">
  <div style="margin-bottom: 24px;">
    <a href="/admin" style="color: var(--accent); text-decoration: none;">&larr; <span data-i18n="admin.backToAdmin">Back to Admin</span></a>
  </div>
  
  <h1 style="font-size: 1.8rem; font-weight: 700; margin-bottom: 24px; font-family: var(--font-serif);" data-i18n="admin.databaseBackup">Database Backup & Restore</h1>
  
  <!-- Export Section -->
  <div class="fm-card" style="padding: 24px; margin-bottom: 24px;">
    <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.backupExport">Export Backup</h2>
    <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.875rem;" data-i18n="admin.backupExportDesc">
      Create a complete backup of all data (users, spools, filaments, settings, etc.) as JSON file.
    </p>
    <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--warning-bg); border: 1px solid var(--warning-border); border-radius: 8px; margin-bottom: 16px;">
      <span style="font-size: 1.25rem;">⚠️</span>
      <div style="font-size: 0.875rem; color: var(--warning-text);">
        <strong data-i18n="admin.backupWarningTitle">Warning:</strong>
        <span data-i18n="admin.backupWarningText">This file contains sensitive data (passwords, API keys). Store it securely!</span>
      </div>
    </div>
    <button id="btn-export-backup" class="fm-btn fm-btn-primary" data-i18n="admin.backupExportBtn">
      Export Backup
    </button>
  </div>

  <!-- Import Section -->
  <div class="fm-card" style="padding: 24px;">
    <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 8px;" data-i18n="admin.backupImport">Import Backup</h2>
    <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 0.875rem;" data-i18n="admin.backupImportDesc">
      Restore a previously exported backup. This will replace all existing data.
    </p>
    <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--error-bg); border: 1px solid var(--error-border); border-radius: 8px; margin-bottom: 16px;">
      <span style="font-size: 1.25rem;">🚨</span>
      <div style="font-size: 0.875rem; color: var(--error-text);">
        <strong data-i18n="admin.backupDangerTitle">Danger:</strong>
        <span data-i18n="admin.backupDangerText">This will DELETE ALL existing data! An automatic backup will be created first.</span>
      </div>
    </div>
    <div style="display: flex; gap: 12px; align-items: end; margin-bottom: 16px;">
      <div style="flex: 1;">
        <label style="display: block; margin-bottom: 4px; font-weight: 500; font-size: 0.875rem;">
          <span data-i18n="admin.backupImportFile">Select Backup File</span>
        </label>
        <input 
          type="file" 
          id="backup-file-input" 
          accept=".json"
          style="display: block; width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; background: var(--bg); color: var(--text);"
        />
      </div>
      <button id="btn-import-backup" class="fm-btn fm-btn-danger" disabled data-i18n="admin.backupImportBtn">
        Import Backup
      </button>
    </div>
    <div id="import-progress" style="display: none;">
      <div style="background: var(--bg-soft); height: 6px; border-radius: 999px; overflow: hidden;">
        <div id="import-progress-bar" style="width: 0%; height: 100%; background: var(--accent); transition: width 0.3s;"></div>
      </div>
      <p id="import-status" style="margin-top: 8px; font-size: 0.875rem; color: var(--text-muted);"></p>
    </div>
  </div>

  <script>
    import { initI18n, t } from '../../lib/i18n'
    initI18n()

    function getCsrfToken(): string {
      const match = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]*)/)
      return match ? decodeURIComponent(match[1]) : ''
    }

    const btnExportBackup = document.getElementById('btn-export-backup') as HTMLButtonElement
    const btnImportBackup = document.getElementById('btn-import-backup') as HTMLButtonElement
    const backupFileInput = document.getElementById('backup-file-input') as HTMLInputElement
    const importProgress = document.getElementById('import-progress')!
    const importProgressBar = document.getElementById('import-progress-bar') as HTMLElement
    const importStatus = document.getElementById('import-status')!

    backupFileInput.addEventListener('change', () => {
      btnImportBackup.disabled = !backupFileInput.files || backupFileInput.files.length === 0
    })

    btnExportBackup.addEventListener('click', async () => {
      btnExportBackup.disabled = true
      const originalText = btnExportBackup.textContent
      btnExportBackup.textContent = t('admin.backupExporting') || 'Exporting...'

      try {
        const response = await fetch('/api/v1/admin/system/backup/export', {
          credentials: 'include',
          headers: { 'X-CSRF-Token': getCsrfToken() }
        })

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ detail: { message: 'Export failed' } }))
          throw new Error(errorData.detail?.message || 'Export failed')
        }

        const blob = await response.blob()
        const contentDisposition = response.headers.get('Content-Disposition')
        let filename = 'filaman_backup.json'
        if (contentDisposition) {
          const match = contentDisposition.match(/filename="(.+)"/)
          if (match) filename = match[1]
        }

        const url = window.URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = filename
        document.body.appendChild(a)
        a.click()
        window.URL.revokeObjectURL(url)
        document.body.removeChild(a)

        await (window as any).__fmAlert(t('admin.backupExportSuccess') || 'Backup exported successfully')
      } catch (err: any) {
        console.error('Export failed:', err)
        await (window as any).__fmAlert(t('admin.backupExportFailed') || `Export failed: ${err.message}`)
      } finally {
        btnExportBackup.disabled = false
        btnExportBackup.textContent = originalText
      }
    })

    btnImportBackup.addEventListener('click', async () => {
      const file = backupFileInput.files?.[0]
      if (!file) return

      const confirmMsg = t('admin.backupImportConfirm') || 
        'Are you sure you want to import this backup?\n\nThis will DELETE ALL existing data!\n\nAn automatic backup will be created first.'
      
      const confirmed = await (window as any).__fmConfirm(confirmMsg)
      if (!confirmed) return

      btnImportBackup.disabled = true
      const originalText = btnImportBackup.textContent
      btnImportBackup.textContent = t('admin.backupImporting') || 'Importing...'
      
      importProgress.style.display = 'block'
      importProgressBar.style.width = '10%'
      importStatus.textContent = t('admin.backupImportPreparing') || 'Preparing import...'

      try {
        const formData = new FormData()
        formData.append('file', file)

        importProgressBar.style.width = '30%'
        importStatus.textContent = t('admin.backupImportUploading') || 'Uploading backup file...'

        const response = await fetch('/api/v1/admin/system/backup/import', {
          method: 'POST',
          credentials: 'include',
          headers: { 'X-CSRF-Token': getCsrfToken() },
          body: formData
        })

        importProgressBar.style.width = '90%'
        importStatus.textContent = t('admin.backupImportProcessing') || 'Processing import...'

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({ detail: { message: 'Import failed' } }))
          throw new Error(errorData.detail?.message || 'Import failed')
        }

        const result = await response.json()

        importProgressBar.style.width = '100%'
        importStatus.textContent = t('admin.backupImportComplete') || 'Import complete!'

        await (window as any).__fmAlert(
          (t('admin.backupImportSuccess') || 'Backup imported successfully!') + '\n\n' + result.message
        )

        backupFileInput.value = ''
        btnImportBackup.disabled = true

        setTimeout(() => {
          window.location.reload()
        }, 2000)

      } catch (err: any) {
        console.error('Import failed:', err)
        importProgressBar.style.width = '0%'
        importStatus.textContent = ''
        await (window as any).__fmAlert(
          (t('admin.backupImportFailed') || 'Import failed:') + '\n\n' + err.message
        )
      } finally {
        setTimeout(() => {
          importProgress.style.display = 'none'
          importProgressBar.style.width = '0%'
          importStatus.textContent = ''
          btnImportBackup.disabled = !backupFileInput.files || backupFileInput.files.length === 0
          btnImportBackup.textContent = originalText
        }, 3000)
      }
    })
  </script>
</Layout>
